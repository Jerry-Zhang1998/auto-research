# macOS
.DS_Store
**/.DS_Store

# Cloned official repos (can be large, re-fetched by fetch_repo.py)
analyses/**/_official_repo/

# Figure base64 sidecar (regenerated by extract_figures.py; embedded into HTML at build)
analyses/**/figures/arch_b64.txt

# Training logs and checkpoints (runtime artifacts)
logs/

# Session log
.claude/session.log

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Datasets (too large for git; use DVC or manual download)
datasets/**/raw/
datasets/**/processed/
datasets/**/splits/
